    "format": "biome format --write src/"
  },
  "devDependencies": {
    "@praxis/typescript-config": "workspace:*",
    "tsup": "^8.0.2",
    "typescript": "^5.3.3",
    "@biomejs/biome": "1.5.3"
  },
  
  "dependencies": {
    "zod": "^3.22.4"
  }
}